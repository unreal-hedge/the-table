    "next": "14.2.35",
    "partyserver": "^0.5.8",
    "partysocket": "^1.3.0",
    "poker-ts": "^1.5.0",
    "pokersolver": "^2.1.4",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "patch-package": "^8.0.1",
    "typescript": "^5",
    "wrangler": "^4.110.0"
  }
